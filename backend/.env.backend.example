# AbheePay Backend Environment Variables
# Copy this to .env and fill in the values

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://neondb_owner:password@your-neon-host/neondb?sslmode=require&channel_binding=require"

# Port to run the server on
PORT=4000

# Backend JWT secret for Neon-auth sessions
BACKEND_JWT_SECRET=change_this_backend_secret

# InstantPay API credentials
INSTANTPAY_API_KEY=your_api_key_here
INSTANTPAY_CLIENT_ID=your_client_id_here
INSTANTPAY_BASE_URL=https://api.instantpay.in

# CORS: your frontend URL
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# Optional: Google Custom Search API (for marketing service detail snippets)
# Create a Custom Search Engine (CSE) and enable the Custom Search JSON API.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Optional: Contact form email delivery (Resend)
# Create an API key in Resend and set a verified "from" address/domain.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@abheepay.com
CONTACT_TO_EMAIL=sales@abheepay.com
